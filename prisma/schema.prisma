generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts    Account[]
  sessions    Session[]
  projects    Project[]
  experiences Experience[]
  config      Config[]
  legalPages  LegalPage[]
  serviceCards ServiceCard[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Project {
  id              String   @id @default(cuid())
  title           String
  category        String
  description     String   @db.Text
  longDescription String   @db.Text
  technologies    Json     // Array de strings
  gradient        String
  textColor       String
  bgColor         String
  videoUrl        String?  // URL opcional de YouTube/Vimeo para embeber
  imageUrl        String?  // URL de imagen en Cloudinary
  imagePublicId   String?  // Public ID en Cloudinary para gestionar borrados
  features        Json     // Array de strings
  metrics         Json     // Objeto con métricas
  isFeatured      Boolean  @default(false)
  userId          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Experience {
  id          String   @id @default(cuid())
  position    String   // Ej: "Senior Full Stack Developer"
  company     String   // Ej: "TechCorp Solutions"
  period      String   // Ej: "2022 - Presente"
  description String   @db.Text
  isCurrent   Boolean  @default(false)
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("experiences")
}

model Config {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  userId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LegalPage {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  content   String   @db.Text
  userId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ServiceCard {
  id          String   @id @default(cuid())
  title       String   @unique
  description String   @db.Text
  bullets     Json
  theme       String   // e.g., 'blue' | 'purple' | 'pink' | 'green' | 'orange' | 'indigo' | 'red' | 'yellow' | 'teal' | 'cyan'
  order       Int      @default(0)
  active      Boolean  @default(true)
  userId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
}
